<Window x:Class="OpenAs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OpenAs" Height="720" Width="1040" MinHeight="650" MinWidth="900"
        Icon="Assets/icon.ico"
        Background="#F4F6F8" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#172033" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#536174" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D8DEE8" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="ControlBorderBrush" Color="#C5CEDA" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="11,7" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F7F9FC" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#AEB8C7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EEF2F7" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,18,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="#B42318" />
            <Setter Property="BorderBrush" Value="#F0B8B2" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="28" HorizontalAlignment="Center" MaxWidth="1120">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="420" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,8,0,22">
                <TextBlock Text="OpenAs" FontSize="30" FontWeight="SemiBold" />
                <TextBlock Text="Map custom extensions to real file types for your Windows user account."
                           Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
            </StackPanel>

            <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Padding="18" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*" MinWidth="260" />
                        <ColumnDefinition Width="1.25*" MinWidth="260" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Custom extension" Style="{StaticResource FieldLabel}" Margin="0,0,16,7" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Search file types" Style="{StaticResource FieldLabel}" Margin="0,0,16,7" />

                    <TextBox x:Name="ExtensionTextBox" Grid.Row="1" Grid.Column="0" Margin="0,0,16,0"
                             ToolTip="Example: .finger" />
                    <TextBox x:Name="FormatSearchTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,16,0"
                             ToolTip="Search by extension, file type, or app"
                             TextChanged="FormatSearchTextBox_TextChanged" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Open as" Style="{StaticResource FieldLabel}" Margin="0,14,16,7" />
                    <ComboBox x:Name="FormatComboBox" Grid.Row="3" Grid.Column="1" Margin="0,0,16,0"
                              DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                              IsTextSearchEnabled="True" TextSearch.TextPath="DisplayName"
                              MaxDropDownHeight="320" />
                    <Button Grid.Row="1" Grid.Column="2" Content="Add mapping" Style="{StaticResource PrimaryButton}"
                            Click="AddMapping_Click" VerticalAlignment="Top" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Text="Icon" Style="{StaticResource FieldLabel}" Margin="0,18,0,8" />
                    <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <RadioButton x:Name="DefaultIconRadioButton" Grid.Column="0" Content="Use default type icon"
                                     IsChecked="True" Checked="DefaultIcon_Checked" />
                        <RadioButton x:Name="CustomIconRadioButton" Grid.Column="1" Content="Use custom icon"
                                     Checked="CustomIcon_Checked" />
                        <TextBox x:Name="IconPathTextBox" Grid.Column="2" IsReadOnly="True" IsEnabled="False"
                                 ToolTip="Optional .ico file copied into OpenAs app data." />
                        <Button x:Name="ChooseIconButton" Grid.Column="3" Content="Choose .ico" Margin="10,0,0,0"
                                IsEnabled="False" Click="ChooseIcon_Click" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Padding="18" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,14,0">
                        <TextBlock Text="Test a file" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock x:Name="TestResultTextBlock" Text="Choose a file to see which supported type OpenAs detects."
                                   Foreground="{StaticResource MutedTextBrush}" Margin="0,5,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Choose file" Margin="12,0,0,0" Click="TestFile_Click" />
                    <Button Grid.Column="2" Content="Reset all mappings" Margin="10,0,0,0"
                            Style="{StaticResource DangerButton}" Click="ResetAll_Click" />
                </Grid>
            </Border>

            <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="18,16,18,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Current mappings" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Refresh" MinWidth="92" Click="Refresh_Click" />
                    </Grid>
                    <DataGrid x:Name="AssociationsGrid" Grid.Row="1"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              HeadersVisibility="Column" SelectionMode="Single" BorderThickness="0"
                              GridLinesVisibility="Horizontal" AlternatingRowBackground="#F8FAFC"
                              RowHeight="36" ColumnHeaderHeight="34">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Extension" Binding="{Binding Extension}" Width="140" />
                            <DataGridTextColumn Header="Opens as" Binding="{Binding OpensAs}" Width="220" />
                            <DataGridTextColumn Header="Icon" Binding="{Binding IconMode}" Width="180" />
                            <DataGridTextColumn Header="Behavior" Binding="{Binding Behavior}" Width="*" MinWidth="180" />
                            <DataGridTemplateColumn Header="Action" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Remove" MinHeight="30" Padding="12,4" Click="RemoveMapping_Click" Tag="{Binding Association}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <TextBlock x:Name="StatusTextBlock" Grid.Row="4" Margin="0,14,0,8" Foreground="#465162"
                       TextWrapping="Wrap" />
        </Grid>
    </ScrollViewer>
</Window>
